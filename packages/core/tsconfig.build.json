{
  "extends": "./tsconfig.json",
  "include": ["src"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "skipLibCheck": true,
    "noEmit": false,
    "allowImportingTsExtensions": false
  }
}
